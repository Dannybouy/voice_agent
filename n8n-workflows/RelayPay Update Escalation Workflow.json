    {
      "id": "c7d8e9f0-a1b2-3456-0123-667788990011",
      "name": "Calculate New Appointment Time",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1620, 80],
      "parameters": {
        "jsCode": "// Merge new values over existing Airtable record fields\nconst updateData = $('Extract Update Data').first().json;\nconst airtableRecord = $input.first().json;\n\nconst recordId = airtableRecord.id;\nconst oldAppointmentTime = airtableRecord['Appointment Time'];\nconst callerName = updateData.newCallerName || airtableRecord['User Name'];\nconst callerEmail = updateData.newCallerEmail || airtableRecord['User Email'];\nconst category = updateData.newCategory || airtableRecord['Category'];\nconst status = updateData.newStatus || airtableRecord['Status'] || 'Open';\n\nlet appointmentStart;\nlet timeChanged = false;\n\nif (updateData.newPreferredTime) {\n  appointmentStart = parseNaturalTime(updateData.newPreferredTime);\n  if (!appointmentStart || isNaN(appointmentStart.getTime()) || appointmentStart < new Date()) {\n    appointmentStart = getNextBusinessDay();\n  }\n  timeChanged = true;\n} else {\n  appointmentStart = new Date(oldAppointmentTime);\n}\n\nconst appointmentEnd = new Date(appointmentStart);\nappointmentEnd.setMinutes(appointmentEnd.getMinutes() + 30);\n\nconst appointmentDisplay = appointmentStart.toLocaleString('en-NG', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit',\n  timeZone: 'Africa/Lagos'\n});\n\nfunction parseNaturalTime(input) {\n  const text = input.toLowerCase().trim();\n  const now = new Date();\n  const watNow = new Date(now.getTime() + (1 * 60 * 60 * 1000));\n  let hour = 10;\n  let minute = 0;\n  const timeMatch = text.match(/(\\d{1,2})(?::(\\d{2}))?\\s*(am|pm)?/i);\n  if (timeMatch) {\n    hour = parseInt(timeMatch[1]);\n    minute = timeMatch[2] ? parseInt(timeMatch[2]) : 0;\n    const ampm = timeMatch[3];\n    if (ampm) {\n      if (ampm.toLowerCase() === 'pm' && hour < 12) hour += 12;\n      if (ampm.toLowerCase() === 'am' && hour === 12) hour = 0;\n    } else if (hour < 8) {\n      hour += 12;\n    }\n  }\n  if (!timeMatch) {\n    if (text.includes('morning')) hour = 10;\n    else if (text.includes('afternoon')) hour = 14;\n    else if (text.includes('evening')) hour = 17;\n  }\n  let targetDate = new Date(watNow);\n  if (text.includes('today')) {\n    // keep today\n  } else if (text.includes('tomorrow')) {\n    targetDate.setDate(targetDate.getDate() + 1);\n  } else if (text.includes('next week')) {\n    targetDate.setDate(targetDate.getDate() + 7);\n    while (targetDate.getDay() !== 1) targetDate.setDate(targetDate.getDate() + 1);\n  } else {\n    const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];\n    const foundDay = days.findIndex(d => text.includes(d));\n    if (foundDay !== -1) {\n      const currentDay = watNow.getDay();\n      let daysUntil = foundDay - currentDay;\n      if (daysUntil <= 0) daysUntil += 7;\n      targetDate.setDate(targetDate.getDate() + daysUntil);\n    } else if (text.includes('in') && text.includes('hour')) {\n      const hoursMatch = text.match(/in\\s+(\\d+|an?)\\s+hour/);\n      if (hoursMatch) {\n        const hrs = hoursMatch[1] === 'an' || hoursMatch[1] === 'a' ? 1 : parseInt(hoursMatch[1]);\n        targetDate = new Date(watNow.getTime() + (hrs * 60 * 60 * 1000));\n        hour = targetDate.getUTCHours();\n        minute = targetDate.getUTCMinutes();\n      }\n    } else {\n      targetDate.setDate(targetDate.getDate() + 1);\n    }\n  }\n  targetDate.setUTCHours(hour - 1, minute, 0, 0);\n  const utcHour = targetDate.getUTCHours();\n  if (utcHour < 8) targetDate.setUTCHours(8, 0, 0, 0);\n  if (utcHour >= 16) {\n    targetDate.setUTCHours(8, 0, 0, 0);\n    targetDate.setDate(targetDate.getDate() + 1);\n  }\n  while (targetDate.getDay() === 0 || targetDate.getDay() === 6) {\n    targetDate.setDate(targetDate.getDate() + 1);\n  }\n  return targetDate;\n}\n\nfunction getNextBusinessDay() {\n  const now = new Date();\n  let next = new Date(now);\n  next.setDate(next.getDate() + 1);\n  while (next.getDay() === 0 || next.getDay() === 6) next.setDate(next.getDate() + 1);\n  next.setUTCHours(9, 0, 0, 0);\n  return next;\n}\n\nreturn [{\n  json: {\n    toolCallId: updateData.toolCallId,\n    recordId,\n    callerName,\n    callerEmail,\n    category,\n    status,\n    appointmentStart: appointmentStart.toISOString(),\n    appointmentEnd: appointmentEnd.toISOString(),\n    appointmentDisplay,\n    timeChanged,\n    oldAppointmentStart: oldAppointmentTime,\n    oldCallerName: airtableRecord['User Name']\n  }\n}];"
      }
    },
