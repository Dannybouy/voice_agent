      "parameters": {
        "jsCode": "const events = $input.all();\nconst calcData = $('Calculate New Appointment Time').first().json;\n\nlet calendarEventId = null;\n\nfor (const event of events) {\n  const summary = event.json.summary || '';\n  if (summary.includes('RelayPay Support Callback')) {\n    calendarEventId = event.json.id;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ...calcData,\n    calendarEventId,\n    calendarEventFound: calendarEventId !== null\n  }\n}];"
      }
