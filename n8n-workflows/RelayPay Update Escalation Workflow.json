    {
      "id": "d2e3f4a5-b6c7-8901-bcde-112233445566",
      "name": "Extract Update Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300],
      "parameters": {
        "jsCode": "// Extract update payload from VAPI tool call\nconst body = $input.first().json.body;\n\nif (!body || !body.message) {\n  return [{ json: { isToolCall: false, toolCallId: '' } }];\n}\n\nconst message = body.message;\nconst toolCallList = message.toolCallList;\n\nif (!toolCallList || toolCallList.length === 0) {\n  return [{ json: { isToolCall: false, toolCallId: '' } }];\n}\n\nconst toolCall = toolCallList[0];\nconst args = toolCall.function?.arguments;\nconst parsedArgs = typeof args === 'string' ? JSON.parse(args) : args;\n\nreturn [{\n  json: {\n    isToolCall: true,\n    toolCallId: toolCall.id,\n    callId: parsedArgs.call_id || message.call?.id || '',\n    newPreferredTime: parsedArgs.preferred_time || null,\n    newCallerName: parsedArgs.user_name || null,\n    newCallerEmail: parsedArgs.user_email || null,\n    newCategory: parsedArgs.category || null,\n    newStatus: parsedArgs.status || null\n  }\n}];"
      }
    },
