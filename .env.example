# RelayPay Voice Agent — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── VAPI ──────────────────────────────────────────────────────
# Get from: VAPI Dashboard > Account > API Keys
VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=
# Get after creating the assistant in Stage 3
VAPI_ASSISTANT_ID=

# ── Supabase ──────────────────────────────────────────────────
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (embeddings only) ──────────────────────────────────
# Used by n8n for text-embedding-3-small. Not used as the LLM.
OPENAI_API_KEY=

# ── Airtable ──────────────────────────────────────────────────
# Personal Access Token: Airtable > Account > Developer Hub > Personal access tokens
AIRTABLE_TOKEN=
# Base ID: visible in the Airtable base URL — https://airtable.com/[BASE_ID]/...
AIRTABLE_BASE_ID=

# ── Email (escalation notifications) ─────────────────────────
# Configure in n8n as an SMTP credential and also set these for env-based config
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@relaypay.io
# The support team inbox that receives escalation notifications
ESCALATION_EMAIL=support@relaypay.io

# ── Knowledge Base ────────────────────────────────────────────
# Direct download URL for the KB PDF in Google Drive
# Format: https://drive.google.com/uc?export=download&id=FILE_ID
KB_PDF_URL=
